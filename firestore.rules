rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isNerae() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().nickname == '너래';
    }

    function isNeraeOrLeader() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          userDoc().nickname == '너래' ||
          userDoc().role == '리더'
        );
    }

    /** 관리자 패널(AdminTypes.checkAdminAccess)과 동일: 너래 / 리더 / 운영진 */
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          userDoc().nickname == '너래' ||
          userDoc().role == '리더' ||
          userDoc().role == '운영진'
        );
    }

    function contestDoc(contestId) {
      return get(/databases/$(database)/documents/contests/$(contestId)).data;
    }

    function roundDoc(contestId, roundId) {
      return get(/databases/$(database)/documents/contests/$(contestId)/rounds/$(roundId)).data;
    }

    function isContestTypeAutoJoin(contestId) {
      return contestDoc(contestId).type == '경연' || contestDoc(contestId).type == '라운드매치';
    }

    function isParticipantSelfWrite(docId) {
      return request.auth.uid == docId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.nickname is string;
    }

    function isRoundVoteSelfWrite(voteId) {
      return request.auth.uid == voteId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.choice in ['A', 'B']
        && request.resource.data.nickname is string;
    }

    /**
     * users: 로그인 전 닉네임→이메일 조회(Login.tsx)와 게시판에서의 프로필 읽기가 필요해 read 공개.
     * (예전 테스트 모드에 가깝게 동작 — 민감 필드는 클라이언트에 노출하지 않도록 앱에서 제한 권장)
     */
    match /users/{userId} {
      allow read: if true;
      allow create: if isSelf(userId) || isAdmin();
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isSelf(userId) || isAdmin();

      match /pushTokens/{tokenId} {
        allow read, write: if isSelf(userId) || isAdmin();
      }
    }

    match /anonymousChatProfiles/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subAccounts', 'activePersona'])
          || isNeraeOrLeader()
        );
      allow delete: if isSelf(userId);
    }

    match /anonymousChatRooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();

      match /participants/{participantId} {
        allow read: if signedIn();
        allow create, update: if signedIn();
        allow delete: if signedIn();
      }

      /** 메시지 uid는 participant 문서 ID라 auth.uid와 다를 수 있음 (부계정 등) */
      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && resource.data.toUid == request.auth.uid;
      allow create: if signedIn();
      allow update: if signedIn()
        && resource.data.toUid == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.toUid == request.auth.uid;
    }

    // ── 게시판: 목록 일부 라우트는 비보호라 읽기 공개(권한 없으면 빈 목록). 쓰기는 로그인 ──
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /guestbook/{docId} {
      allow read, write: if signedIn();
    }

    match /anonymousNotes/{docId} {
      allow read, write: if signedIn();
    }

    match /approvedSongs/{docId} {
      allow read, write: if signedIn();
    }

    function canManageSetList() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          userDoc().role == '리더' ||
          userDoc().role == '조장'
        );
    }

    function isLeaderRole() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == '리더';
    }

    function isSetlistHost() {
      return signedIn()
        && resource.data.hostUid == request.auth.uid;
    }

    function isBuskingSessionManager() {
      return isSetlistHost() || isLeaderRole() || isNerae();
    }

    function isBuskingSessionParticipant() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          userDoc().nickname in resource.data.get('participants', [])
          || userDoc().nickname in resource.data.get('freeSongParticipants', [])
        );
    }

    function touchesBuskingManagementFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'participants',
        'freeSongParticipants',
        'status',
        'isActive',
        'isCompleted',
        'completedAt',
        'songs',
        'flexibleCards',
        'requestSongCards',
        'hostUid',
        'hostNickname',
        'venueLabel',
        'name',
        'sessionDate',
        'freeSongMemberStats'
      ]);
    }

    match /setlists/{setlistId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'live';
      allow update: if signedIn() && (
        isBuskingSessionManager() ||
        (isBuskingSessionParticipant() && !touchesBuskingManagementFields())
      );
      allow delete: if canManageSetList()
        && (
          isLeaderRole() ||
          isSetlistHost() ||
          !('hostUid' in resource.data)
        );
      match /chatMessages/{msgId} {
        allow read, write: if signedIn();
      }
    }

    match /buskingStats/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['performers', 'updatedAt']);
      allow delete: if canManageSetList();
    }

    match /playlistSongs/{docId} {
      allow read, write: if signedIn();
    }

    match /specialMoments/{docId} {
      allow read, write: if signedIn();
    }

    /** 홈 노트 본문 — 읽기: 로그인, 쓰기: 리더·운영진 (너래 = 리더) */
    function canEditHomeNotebook() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          userDoc().role == '리더' ||
          userDoc().role == '운영진'
        );
    }

    match /homeNotebook/{docId} {
      allow read: if signedIn();
      allow write: if canEditHomeNotebook();
    }

    match /boardVisits/{docId} {
      allow read, write: if signedIn();
    }

    match /blockingRules/{docId} {
      allow read, write: if signedIn();
    }

    match /admin_deletion_records/{docId} {
      allow read, write: if signedIn();
    }

    match /approved_song_deletion_audit/{docId} {
      allow read, write: if signedIn();
    }

    match /emailRegistrationHistory/{docId} {
      allow read, write: if signedIn();
    }

    match /practiceRoomSettings/{docId} {
      allow read, write: if signedIn();
    }

    /** 연습실 예약·체크인·시간 차단 (배포 누락 시 예약 현황이 비어 보임) */
    match /practiceRoomReservations/{docId} {
      allow read, write: if signedIn();
    }

    match /practiceRoomCheckIn/{docId} {
      allow read, write: if signedIn();
    }

    match /blockedTimeSlots/{docId} {
      allow read, write: if signedIn();
    }

    match /practiceSongs/{docId} {
      allow read, write: if signedIn();
    }

    match /practiceSuggestions/{docId} {
      allow read, write: if signedIn();
    }

    match /practiceSchedules/{docId} {
      allow read, write: if signedIn();
    }

    match /customerInquiries/{inquiryId} {
      allow read, write: if signedIn();
      match /messages/{msgId} {
        allow read, write: if signedIn();
      }
    }

    match /contests/{contestId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isNeraeOrLeader();
      match /participants/{docId} {
        allow read: if signedIn();
        allow create: if signedIn() && (
          isNeraeOrLeader() ||
          (
            isContestTypeAutoJoin(contestId) &&
            (
              !contestDoc(contestId).isStarted ||
              (contestDoc(contestId).isStarted && isNeraeOrLeader())
            ) &&
            isParticipantSelfWrite(docId)
          )
        );
        allow update, delete: if isNeraeOrLeader();
      }
      match /teams/{docId} {
        allow read: if signedIn();
        allow write: if isNeraeOrLeader();
      }
      match /grades/{docId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update, delete: if isNeraeOrLeader();
      }
      match /evaluationTargets/{docId} {
        allow read: if signedIn();
        allow write: if isNeraeOrLeader();
      }
      match /rounds/{roundId} {
        allow read: if signedIn();
        allow write: if isNeraeOrLeader();
        match /votes/{voteId} {
          allow read: if signedIn();
          allow create, update: if signedIn()
            && roundDoc(contestId, roundId).status == 'voting'
            && (
              isNeraeOrLeader() ||
              (
                exists(/databases/$(database)/documents/contests/$(contestId)/participants/$(request.auth.uid))
                && isRoundVoteSelfWrite(voteId)
              )
            );
          allow delete: if isNeraeOrLeader();
        }
      }
    }

    match /conversations/{conversationId} {
      allow read, write: if signedIn();
      match /messages/{msgId} {
        allow read, write: if signedIn();
      }
    }

    match /announcementBanned/{docId} {
      allow read, write: if signedIn();
    }

    match /admin_logs/{docId} {
      allow read, write: if signedIn();
    }

    match /notification_templates/{docId} {
      allow read, write: if signedIn();
    }

    match /user_activities/{docId} {
      allow read, write: if signedIn();
    }

    /** 미니게임 점수 */
    match /games/{gameId} {
      allow read: if signedIn();

      /** 레거시: 시도마다 쌓이던 기록 (신규 저장 안 함) */
      match /scores/{scoreId} {
        allow read: if signedIn();
        allow write: if false;
      }

      /** 레거시 이전 완료 등 내부 메타 */
      match /meta/{metaId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && metaId == 'legacyMigration';
        allow delete: if false;
      }

      /** 주간 초기화 시 보관되는 과거 1위 기록 */
      match /pastChampions/{recordId} {
        allow read: if signedIn();
        allow write: if false;
      }

      /** 플래피 버드: 현재 플레이 중인 세션 (실시간 진행 표시) */
      match /activeSessions/{sessionId} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && gameId == 'flappyBird'
          && request.resource.data.uid == request.auth.uid
          && sessionId == request.resource.data.uid + '_' + request.resource.data.platform
          && request.resource.data.platform in ['pc', 'mobile']
          && request.resource.data.score is number
          && request.resource.data.score >= 0
          && request.resource.data.score <= 9999
          && request.resource.data.birdY is number
          && request.resource.data.birdY >= 0
          && request.resource.data.birdY <= 520
          && request.resource.data.elapsedMs is number
          && request.resource.data.elapsedMs >= 0
          && request.resource.data.elapsedMs <= 120000
          && request.resource.data.personalBest is number
          && request.resource.data.personalBest >= 0
          && request.resource.data.personalBest <= 9999;
        allow delete: if signedIn()
          && gameId == 'flappyBird'
          && resource.data.uid == request.auth.uid;
      }

      /** 사천성: 1v1 / 2v2 룸 */
      match /rooms/{roomId} {
        allow read: if signedIn() && gameId == 'sichuan';

        allow create: if signedIn()
          && gameId == 'sichuan'
          && request.resource.data.hostUid == request.auth.uid
          && request.resource.data.code is string
          && request.resource.data.code.size() == 6
          && request.resource.data.mode in ['1v1', '2v2']
          && request.resource.data.status == 'lobby'
          && request.resource.data.maxPlayers in [2, 4]
          && request.resource.data.playerCount == 0
          && request.resource.data.seed == 0
          && request.resource.data.winnerTeam == null
          && request.resource.data.winnerLabel == null;

        allow update: if signedIn()
          && gameId == 'sichuan'
          && request.resource.data.code == resource.data.code
          && request.resource.data.mode == resource.data.mode
          && request.resource.data.maxPlayers == resource.data.maxPlayers
          && request.resource.data.createdAtMs == resource.data.createdAtMs
          && (
            // 입장: playerCount +1 (로비)
            (
              resource.data.status == 'lobby'
              && request.resource.data.status == 'lobby'
              && request.resource.data.hostUid == resource.data.hostUid
              && request.resource.data.seed == resource.data.seed
              && request.resource.data.playerCount == resource.data.playerCount + 1
              && request.resource.data.playerCount <= resource.data.maxPlayers
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount'])
            )
            // 퇴장: playerCount -1
            || (
              request.resource.data.hostUid == resource.data.hostUid
              && request.resource.data.seed == resource.data.seed
              && request.resource.data.status == resource.data.status
              && request.resource.data.playerCount == resource.data.playerCount - 1
              && request.resource.data.playerCount >= 0
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount'])
            )
            // 방장 승계
            || (
              resource.data.hostUid == request.auth.uid
              && request.resource.data.status == resource.data.status
              && request.resource.data.seed == resource.data.seed
              && request.resource.data.playerCount == resource.data.playerCount
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hostUid'])
            )
            // 게임 시작 (방장, 정원 충족)
            || (
              resource.data.hostUid == request.auth.uid
              && resource.data.status == 'lobby'
              && request.resource.data.status == 'playing'
              && resource.data.playerCount == resource.data.maxPlayers
              && request.resource.data.playerCount == resource.data.playerCount
              && request.resource.data.hostUid == resource.data.hostUid
              && request.resource.data.seed is number
              && request.resource.data.seed > 0
              && request.resource.data.winnerTeam == null
              && request.resource.data.winnerLabel == null
            )
            // 종료 (방장, 시드 불변)
            || (
              resource.data.hostUid == request.auth.uid
              && resource.data.status == 'playing'
              && request.resource.data.status == 'finished'
              && request.resource.data.seed == resource.data.seed
              && request.resource.data.hostUid == resource.data.hostUid
              && request.resource.data.playerCount == resource.data.playerCount
              && request.resource.data.winnerLabel is string
              && request.resource.data.winnerLabel.size() <= 60
            )
          );

        allow delete: if signedIn()
          && gameId == 'sichuan'
          && (
            resource.data.hostUid == request.auth.uid
            || resource.data.playerCount <= 1
          );

        match /players/{playerId} {
          allow read: if signedIn() && gameId == 'sichuan';

          allow create: if signedIn()
            && gameId == 'sichuan'
            && request.auth.uid == playerId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.team in [0, 1]
            && request.resource.data.score == 0
            && request.resource.data.pairs == 0
            && request.resource.data.remaining == 48
            && request.resource.data.finished == false
            && request.resource.data.ready == false
            && request.resource.data.shuffleCount == 0
            && request.resource.data.comboBonus == 0
            && request.resource.data.nickname is string
            && request.resource.data.nickname.size() > 0
            && request.resource.data.nickname.size() <= 24
            && get(/databases/$(database)/documents/games/sichuan/rooms/$(roomId)).data.status == 'lobby'
            && get(/databases/$(database)/documents/games/sichuan/rooms/$(roomId)).data.playerCount
              < get(/databases/$(database)/documents/games/sichuan/rooms/$(roomId)).data.maxPlayers;

          allow update: if signedIn()
            && gameId == 'sichuan'
            && request.auth.uid == playerId
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.team == resource.data.team
            && request.resource.data.nickname == resource.data.nickname
            && request.resource.data.pairs is number
            && request.resource.data.pairs >= resource.data.pairs
            && request.resource.data.pairs <= 24
            && request.resource.data.remaining is number
            && request.resource.data.remaining <= resource.data.remaining
            && request.resource.data.remaining >= 0
            && request.resource.data.remaining == 48 - request.resource.data.pairs * 2
            && request.resource.data.get('comboBonus', 0) is number
            && request.resource.data.get('comboBonus', 0) >= 0
            && request.resource.data.get('comboBonus', 0) <= request.resource.data.pairs * 3
            && request.resource.data.get('comboBonus', 0) >= resource.data.get('comboBonus', 0)
            && request.resource.data.score is number
            && request.resource.data.score == request.resource.data.pairs * 10
              + (request.resource.data.remaining == 0 ? 100 : 0)
              + request.resource.data.get('comboBonus', 0)
            && request.resource.data.score <= 412
            && request.resource.data.shuffleCount is number
            && request.resource.data.shuffleCount >= resource.data.shuffleCount
            && request.resource.data.shuffleCount <= 5
            && request.resource.data.finished is bool
            && (resource.data.finished == false || request.resource.data.finished == true)
            && (
              request.resource.data.ready == resource.data.ready
              || get(/databases/$(database)/documents/games/sichuan/rooms/$(roomId)).data.status == 'lobby'
            );

          allow delete: if signedIn()
            && gameId == 'sichuan'
            && request.auth.uid == playerId;
        }
      }

      /** 사용자·플랫폼별 최고 기록 (uid_pc / uid_mobile) */
      match /bestScores/{scoreId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.durationMs is number
          && request.resource.data.platform in ['pc', 'mobile']
          && (
            (gameId == 'typingSpeed' && request.resource.data.durationMs >= 500)
            || (gameId == 'reactionTime'
              && request.resource.data.durationMs >= 100
              && request.resource.data.durationMs <= 15000)
            || (gameId == 'rhythmBeat'
              && request.resource.data.durationMs >= 0
              && request.resource.data.durationMs <= 300
              && request.resource.data.accuracy is number
              && request.resource.data.accuracy >= 0
              && request.resource.data.accuracy <= 100
              && request.resource.data.accuracy >= (100 - request.resource.data.durationMs * 100 / 300) - 1
              && request.resource.data.accuracy <= (100 - request.resource.data.durationMs * 100 / 300) + 1)
            || (gameId == 'escapeRoom'
              && request.resource.data.durationMs >= 0
              && request.resource.data.durationMs <= 9999999
              && request.resource.data.rankScore is number
              && request.resource.data.rankScore >= 0
              && request.resource.data.rankScore <= 9999999)
            || (gameId == 'flappyBird'
              && request.resource.data.durationMs >= 0
              && request.resource.data.durationMs <= 9999
              && (!('replay' in request.resource.data)
                || (request.resource.data.replay is list
                  && request.resource.data.replay.size() <= 400))
              && (!('lastRunScore' in request.resource.data)
                || (request.resource.data.lastRunScore is number
                  && request.resource.data.lastRunScore >= 0
                  && request.resource.data.lastRunScore <= 9999))
              && (!('lastRunReplay' in request.resource.data)
                || (request.resource.data.lastRunReplay is list
                  && request.resource.data.lastRunReplay.size() <= 400)))
          );
        allow update: if signedIn()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.durationMs is number
          && request.resource.data.platform in ['pc', 'mobile']
          && (
            (gameId == 'typingSpeed' && request.resource.data.durationMs >= 500)
            || (gameId == 'reactionTime'
              && request.resource.data.durationMs >= 100
              && request.resource.data.durationMs <= 15000)
            || (gameId == 'rhythmBeat'
              && request.resource.data.durationMs >= 0
              && request.resource.data.durationMs <= 300
              && request.resource.data.accuracy is number
              && request.resource.data.accuracy >= 0
              && request.resource.data.accuracy <= 100
              && request.resource.data.accuracy >= (100 - request.resource.data.durationMs * 100 / 300) - 1
              && request.resource.data.accuracy <= (100 - request.resource.data.durationMs * 100 / 300) + 1)
            || (gameId == 'escapeRoom'
              && request.resource.data.durationMs >= 0
              && request.resource.data.durationMs <= 9999999
              && request.resource.data.rankScore is number
              && request.resource.data.rankScore >= 0
              && request.resource.data.rankScore <= 9999999)
            || (gameId == 'flappyBird'
              && request.resource.data.durationMs >= 0
              && request.resource.data.durationMs <= 9999
              && (!('replay' in request.resource.data)
                || (request.resource.data.replay is list
                  && request.resource.data.replay.size() <= 400))
              && (!('lastRunScore' in request.resource.data)
                || (request.resource.data.lastRunScore is number
                  && request.resource.data.lastRunScore >= 0
                  && request.resource.data.lastRunScore <= 9999))
              && (!('lastRunReplay' in request.resource.data)
                || (request.resource.data.lastRunReplay is list
                  && request.resource.data.lastRunReplay.size() <= 400)))
          );
        allow delete: if false;
      }

      /** 사천성 멀티 승/패 전적 */
      match /records/{recordId} {
        allow read: if signedIn() && gameId == 'sichuan';

        allow create: if signedIn()
          && gameId == 'sichuan'
          && request.auth.uid == recordId
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() > 0
          && request.resource.data.nickname.size() <= 24
          && request.resource.data.wins is number
          && request.resource.data.wins >= 0
          && request.resource.data.wins <= 1
          && request.resource.data.losses is number
          && request.resource.data.losses >= 0
          && request.resource.data.losses <= 1
          && request.resource.data.draws is number
          && request.resource.data.draws >= 0
          && request.resource.data.draws <= 1
          && request.resource.data.gamesPlayed is number
          && request.resource.data.gamesPlayed
            == request.resource.data.wins + request.resource.data.losses + request.resource.data.draws
          && request.resource.data.gamesPlayed == 1
          && request.resource.data.updatedAtMs is number
          && request.resource.data.lastMatchKey is string
          && request.resource.data.lastMatchKey.size() > 0
          && request.resource.data.lastMatchKey.size() <= 80;

        allow update: if signedIn()
          && gameId == 'sichuan'
          && request.auth.uid == recordId
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() > 0
          && request.resource.data.nickname.size() <= 24
          && request.resource.data.wins is number
          && request.resource.data.losses is number
          && request.resource.data.draws is number
          && request.resource.data.gamesPlayed is number
          && request.resource.data.wins >= resource.data.wins
          && request.resource.data.losses >= resource.data.losses
          && request.resource.data.draws >= resource.data.draws
          && request.resource.data.wins <= resource.data.wins + 1
          && request.resource.data.losses <= resource.data.losses + 1
          && request.resource.data.draws <= resource.data.draws + 1
          && (request.resource.data.wins + request.resource.data.losses + request.resource.data.draws)
            == (resource.data.wins + resource.data.losses + resource.data.draws + 1)
          && request.resource.data.gamesPlayed
            == request.resource.data.wins + request.resource.data.losses + request.resource.data.draws
          && request.resource.data.gamesPlayed == resource.data.gamesPlayed + 1
          && request.resource.data.updatedAtMs is number
          && request.resource.data.lastMatchKey is string
          && request.resource.data.lastMatchKey.size() > 0
          && request.resource.data.lastMatchKey.size() <= 80
          && request.resource.data.lastMatchKey != resource.data.get('lastMatchKey', '');

        allow delete: if false;
      }
    }
  }
}
